/* 首页样式 */
.index-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1890ff 0%, #52c41a 100%);
}

/* 声明弹窗 */
.warning-box {
  background: #fff3cd;
  padding: 15px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  margin-bottom: 15px;
}

.warning-icon {
  font-size: 24px;
  margin-right: 10px;
}

.warning-text {
  font-size: 14px;
  color: #856404;
  line-height: 1.5;
}

.info-section {
  margin: 15px 0;
}

.section-title {
  font-size: 14px;
  color: #1890ff;
  font-weight: bold;
}

.hotline-list {
  margin-top: 10px;
}

.hotline-row {
  padding: 8px 0;
  font-size: 14px;
  color: #666;
}

.agreement {
  background: #f5f5f5;
  padding: 10px;
  border-radius: 5px;
  margin-top: 15px;
}

.agreement text {
  display: block;
  font-size: 12px;
  color: #666;
  margin: 5px 0;
}

.accept-btn {
  width: 100%;
  background: #1890ff;
  color: white;
  height: 45px;
  font-size: 16px;
}

/* 主内容 */
.main-content {
  padding: 30px 20px;
}

.logo-section {
  text-align: center;
  margin-bottom: 30px;
}

.logo-text {
  font-size: 32px;
  color: white;
  font-weight: bold;
}

.logo-subtitle {
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  margin-top: 10px;
  display: block;
}

/* 功能介绍 */
.features-section {
  background: white;
  border-radius: 15px;
  padding: 20px;
  margin-bottom: 20px;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 15px 0;
  border-bottom: 1px solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 28px;
  margin-right: 15px;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.feature-desc {
  font-size: 12px;
  color: #999;
  margin-top: 5px;
  display: block;
}

/* 热线区域 */
.hotline-section {
  background: white;
  border-radius: 15px;
  padding: 20px;
  margin-bottom: 20px;
}

.hotline-section .section-title {
  display: block;
  margin-bottom: 15px;
}

.hotline-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15px;
  background: #f5f5f5;
  border-radius: 10px;
  margin-top: 10px;
}

.hotline-info {
  flex: 1;
}

.hotline-name {
  font-size: 14px;
  color: #333;
  display: block;
}

.hotline-phone {
  font-size: 16px;
  color: #1890ff;
  font-weight: bold;
  margin-top: 5px;
  display: block;
}

.call-btn {
  background: #52c41a;
  color: white;
  font-size: 14px;
  padding: 8px 15px;
}

/* 操作按钮 */
.action-section {
  margin-top: 30px;
}

.start-btn {
  width: 100%;
  height: 50px;
  background: white;
  color: #1890ff;
  font-size: 18px;
  font-weight: bold;
  border-radius: 25px;
}

.resource-btn {
  width: 100%;
  height: 45px;
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 14px;
  margin-top: 10px;
  border-radius: 22px;
}