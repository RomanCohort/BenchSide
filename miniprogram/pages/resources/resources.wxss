/* 资源页面样式 */
.resources-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60px;
}

.header {
  background: #1890ff;
  color: white;
  padding: 20px;
  text-align: center;
}

.title {
  font-size: 20px;
  font-weight: bold;
}

.subtitle {
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  margin-top: 5px;
  display: block;
}

/* 分类 */
.category-tabs {
  display: flex;
  padding: 10px;
  background: white;
  border-bottom: 1px solid #e8e8e8;
}

.tab {
  padding: 8px 15px;
  font-size: 14px;
  color: #666;
  background: #f5f5f5;
  border-radius: 15px;
  margin: 0 5px;
}

.tab.active {
  background: #1890ff;
  color: white;
}

/* 资源卡片 */
.resource-list {
  padding: 10px;
}

.resource-card {
  background: white;
  margin: 10px 0;
  padding: 15px;
  border-radius: 10px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.card-tags {
  display: flex;
  margin-bottom: 10px;
}

.tag {
  font-size: 11px;
  color: white;
  padding: 3px 8px;
  border-radius: 3px;
  margin-right: 5px;
}

.card-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 10px;
}

.card-phone {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.phone-label {
  font-size: 12px;
  color: #999;
}

.phone-number {
  font-size: 16px;
  color: #1890ff;
  font-weight: bold;
}

.phone-alt {
  font-size: 14px;
  color: #666;
}

.call-btn {
  background: #52c41a;
  color: white;
  font-size: 12px;
  padding: 5px 10px;
  margin-left: auto;
}

.card-address {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.address-label {
  font-size: 12px;
  color: #999;
}

.address-text {
  font-size: 13px;
  color: #333;
  flex: 1;
}

.copy-btn {
  background: #f5f5f5;
  color: #666;
  font-size: 12px;
  padding: 5px 10px;
}

.card-hours, .card-howto {
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.hours-label, .howto-label {
  font-size: 12px;
  color: #999;
  display: block;
}

.hours-text, .howto-text {
  font-size: 13px;
  color: #333;
  margin-top: 5px;
  display: block;
}

.card-note {
  display: flex;
  align-items: flex-start;
  padding: 10px 0;
  background: #fff3cd;
  margin-top: 10px;
  border-radius: 5px;
  padding: 10px;
}

.note-icon {
  font-size: 16px;
  margin-right: 8px;
}

.note-text {
  font-size: 13px;
  color: #856404;
}

.source-tag {
  margin-top: 10px;
  text-align: right;
  font-size: 11px;
  color: #999;
}

/* 紧急Banner */
.emergency-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #dc3545;
  color: white;
  padding: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-icon {
  font-size: 20px;
  margin-right: 10px;
}

.emergency-text {
  font-size: 14px;
}